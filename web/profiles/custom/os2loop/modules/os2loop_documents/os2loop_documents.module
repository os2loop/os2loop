function os2loop_documents_documents_submit(array &$form, FormStateInterface $formState) {
  $helper = \Drupal::service('os2loop_documents.collection_helper');
  $helper->updateCollection();
  header('content-type: text/plain'); echo var_export($formState->get('documents'), true); die(__FILE__.':'.__LINE__.':'.__METHOD__);
}

/**
 *
 */
function os2loop_documents_get_collection_documents(FormStateInterface $form_state, NodeInterface $node) {
  // $data = json_decode($node->os2loop_documents_documents->value, true);
  // $spec = $form_state->getValue('os2loop_documents_documents')[0]['value'] ?? '{}';
  // $data = json_decode($spec, TRUE);
  // if (!is_array($data)) {
  //   $data = [];
  // }
  $data = $form_state->get('documents') ?? [];
  $nodes = Node::loadMultiple(array_keys($data));
  foreach ($data as &$item) {
    if (0 == $item['pid']) {
      $item['depth'] = 0;
    }
    $node = $nodes[$item['id']] ?? NULL;
    $item['name'] = $node ? sprintf('%s (%s)', $node->getTitle(), $node->id()) : $item['id'];
  }

  foreach ($data as &$item) {
    if (!isset($item['depth'])) {
      $item['depth'] = $data[$item['pid']]['depth'] + 1;
    }
    if (!isset($item['weight'])) {
      $item['weight'] = 0;
    }
  }

  return $data;
}

